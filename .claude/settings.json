      "WebFetch(domain:app.autosad.ai)",
      "WebFetch(domain:autosad.ai)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.langchain.com)",
      "WebFetch(domain:blog.langchain.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:openai.com)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:platform.openai.com)",
      "WebFetch(domain:deepwiki.com)",
      "Bash(docker compose:*)",
      "Bash(docker exec:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(uv:*)",
      "Bash(chmod +x:*)",
      "Bash(mkdir:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git status:*)",
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(curl:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep -E '\\\\.\\(ts|js|json\\)$')",
      "Bash(wait)",
      "Bash(rm -rf .next)",
      "Bash(lsof -ti:3000 -ti:3001)",
      "Bash(fuser -k 3000/tcp)",
      "Bash(fuser -k 3001/tcp)"
    ],
    "additionalDirectories": [
      "/home/workspace/aise-v2/frontend/.next"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/aiqa/source/aise2.0/backend && [ -d tests ] && uv run pytest tests/ -q --tb=line 2>&1 | tail -5 || true",
            "timeout": 30,
            "statusMessage": "테스트 실행 중..."
          }
        ]
      }
    ]
  }
}
